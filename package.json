{
  "name": "aura-verifier",
  "version": "0.1.0",
  "description": "Independent CLI and browser verifier for AURA Evidence Packages.",
  "type": "module",
  "bin": {
    "aura": "./bin/aura.js"
  },
  "scripts": {
    "test": "node tests/run-tests.js",
    "generate:test-vector": "node scripts/generate-test-vector.js",
